{
  "name": "@arsv2/runtime",
  "version": "2.0.0",
  "private": true,
  "description": "Layer 4: API server and runtime for ARSV2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "ts-node src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@arsv2/types": "*",
    "@arsv2/config": "*",
    "@arsv2/repo": "*",
    "@arsv2/service": "*",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/cors": "^2.8.17",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0",
    "vitest": "^2.1.0"
  }
}
