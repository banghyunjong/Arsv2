{
  "version": 2,
  "buildCommand": "cd ../.. && npm run build && mkdir -p packages/runtime/docs && cp docs/*.csv packages/runtime/docs/",
  "installCommand": "npm install --prefix=../..",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["docs/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
